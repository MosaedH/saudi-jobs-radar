# Copy this file to ".env" and fill in your free API keys.
# None are committed to git (.env is ignored). On GitHub, add these as
# repository "Secrets" instead (Settings -> Secrets and variables -> Actions).

# JSearch via RapidAPI -> covers LinkedIn, Indeed, Glassdoor, ZipRecruiter, Bayt, etc.
# Get a free key: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch  (Subscribe -> Basic / Free)
RAPIDAPI_KEY=

# Jooble API -> broad aggregator, covers Saudi Arabia.
# Get a free key: https://jooble.org/api/about  (request an API key)
JOOBLE_KEY=

# Careerjet (optional) -> set an affiliate id to enable. Leave blank to skip.
# Register: https://www.careerjet.com/partners/
CAREERJET_AFFID=
